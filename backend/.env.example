PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/pshop?retryWrites=true&w=majority
JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CLIENT_CUSTOMER_URL=http://localhost:5173
CLIENT_SELLER_URL=http://localhost:5174
CLIENT_ADMIN_URL=http://localhost:5175
UPLOAD_DIR=uploads
